[Unit]
Description=GPTAdmin failover FRP client
After=network-online.target gptadmin-hub.service
Wants=network-online.target

[Service]
Type=simple
ExecStart=/opt/gptadmin/bin/frpc -c /etc/gptadmin/frpc-failover.toml
Restart=always
RestartSec=3
NoNewPrivileges=true
PrivateTmp=true
ProtectSystem=full
ProtectHome=true

[Install]
WantedBy=multi-user.target
