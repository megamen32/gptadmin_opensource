name: GPTAdmin ShellMCP
version: "1.0.0"
slug: gptadmin_shellmcp
description: "GPTAdmin ShellMCP agent for Home Assistant OS"
url: "https://gptadmin.bezrabotnyi.com"
arch:
  - aarch64
startup: services
boot: auto
init: false
server-01_api: true
hassio_api: true
hassio_role: admin
auth_api: true
docker_api: true
host_network: true
full_access: true
protected: false
apparmor: false
privileged:
  - SYS_ADMIN
  - NET_ADMIN
map:
  - config:rw
  - ssl:rw
  - addons:rw
  - share:rw
  - backup:rw
  - media:rw
options:
  hub_url: "__HUB_URL__"
  shell_name: "haos"
  shell_url: "__SHELL_URL__"
  shell_token: "__SHELLMCP_TOKEN__"
  port: 25900
  queue: true
  heartbeat: false
  default_cwd: "/config"
  exec_timeout: 300
  log_limit_b: 8192
schema:
  hub_url: str
  shell_name: str
  shell_url: str
  shell_token: password
  port: int
  queue: bool
  heartbeat: bool
  default_cwd: str
  exec_timeout: int
  log_limit_b: int
