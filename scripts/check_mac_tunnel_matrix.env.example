# Copy to scripts/check_mac_tunnel_matrix.env and fill real values.
# scripts/check_mac_tunnel_matrix.env is intentionally ignored by git.

# Required for --backends frp
MAC_TUNNEL_FRP_SERVER_ADDR=frp.example.com
MAC_TUNNEL_FRP_SERVER_PORT=7000
MAC_TUNNEL_FRP_DOMAIN=frp.example.com
MAC_TUNNEL_FRP_TOKEN=replace-with-frp-token

# Optional for --backends ngrok. If empty/missing, ngrok cells are skipped.
# MAC_TUNNEL_NGROK_AUTHTOKEN=replace-with-ngrok-token

# Optional, only needed for --scopes system on Macs where sudo -n requires a password.
# MAC_TUNNEL_SUDO_PASSWORD=replace-with-mac-sudo-password
