#!/usr/bin/env bash
set -euo pipefail
cd "$(dirname "$0")"
if [[ $# -lt 2 ]]; then
  cat >&2 <<'EOF'
Usage:
  ./mcp-add NAME --url https://server.example/mcp [--stdio-format framed]
  ./mcp-add NAME -- npx -y some-mcp-server --arg value
  ./mcp-add NAME npx -y some-mcp-server --arg value

This writes /etc/gptadmin/mcp.json, renders /etc/gptadmin/mcp-agents.d/NAME.json,
installs/enables/starts the systemd relay, and prints status.
EOF
  exit 2
fi
name="$1"; shift
if [[ "${1:-}" == "--" ]]; then shift; fi
exec sudo python3 /home/admin/gptadmin/cli/gptadmin.py mcp add "$name" --force --install --status "$@"
